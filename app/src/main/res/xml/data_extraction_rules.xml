<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="exe_memory.db"/>
        <exclude domain="database" path="exe_memory.db-shm"/>
        <exclude domain="database" path="exe_memory.db-wal"/>
        <exclude domain="sharedpref" path="exe_overlay_prefs.xml"/>
        <exclude domain="sharedpref" path="exe_user_prefs.xml"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="exe_memory.db"/>
    </device-transfer>
</data-extraction-rules>
