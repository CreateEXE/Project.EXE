<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Android.EXE"
            android:textColor="@color/accent"
            android:textSize="28sp"
            android:textStyle="bold"
            android:fontFamily="monospace"
            android:layout_marginBottom="4dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI Companion Setup"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="28dp" />

        <!-- Pet Name -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PET NAME"
            android:textColor="@color/label"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvPetName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Exe"
                android:textColor="@color/text_primary"
                android:textSize="20sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPetName"
                style="@style/Widget.AppCompat.Button.Borderless"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rename"
                android:textColor="@color/accent" />
        </LinearLayout>

        <!-- Avatar -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AVATAR (.vrm / .glb / .gltf)"
            android:textColor="@color/label"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvAvatarPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No avatar loaded"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"
            android:maxLines="2"
            android:ellipsize="start" />

        <Button
            android:id="@+id/btnPickAvatar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Choose Avatar File"
            android:backgroundTint="@color/surface"
            android:textColor="@color/accent"
            android:layout_marginBottom="24dp" />

        <!-- LLM Model -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="AI MODEL (.gguf)"
            android:textColor="@color/label"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvModelPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No model loaded"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="8dp"
            android:maxLines="2"
            android:ellipsize="start" />

        <Button
            android:id="@+id/btnPickModel"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Choose GGUF Model"
            android:backgroundTint="@color/surface"
            android:textColor="@color/accent"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/surface"
            android:layout_marginBottom="20dp" />

        <!-- Permissions status -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PERMISSIONS"
            android:textColor="@color/label"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvOverlayStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking…"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnAccessibility"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Open Accessibility Settings"
            android:backgroundTint="@color/surface"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="24dp" />

        <!-- Start / Stop -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Start Pet"
            android:backgroundTint="@color/accent"
            android:textColor="@color/background"
            android:textStyle="bold"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>
